---
import Layout from "../layouts/Layout.astro"
import SectionContainer from "../components/SectionContainer.astro"
import TitleSection from "../components/TitleSection.astro"
import Tools from "../components/icons/Tools.astro"
---

<Layout
  title="EnerTrack — Documentación del proyecto"
  description="EnerTrack: plataforma web para gestionar producción de energía renovable, métricas ambientales y arquitectura de microservicios."
>
  <main class="px-4">
    <SectionContainer class="py-16 md:py-10">
      <section class="my-10">
        <h1 class="text-4xl font-bold text-gray-900 dark:text-white">EnerTrack</h1>

        <p class="mt-4 text-lg leading-relaxed text-gray-600 dark:text-gray-400">
          EnerTrack es una plataforma web para gestionar la producción de energía renovable a nivel mundial.
          Permite administrar tipos de energía, registros de consumo, métricas ambientales y análisis de
          reducción de emisiones. El sistema está planteado como una arquitectura de microservicios
          escalable para soportar grandes volúmenes de datos.
        </p>

        <p class="mt-4 text-lg font-semibold text-gray-800 dark:text-gray-200">
          Este proyecto está en desarrollo activo.
        </p>

        <h2 class="mt-10 text-xl font-bold text-gray-900 dark:text-white">Funcionalidades destacadas</h2>

        <ul class="mt-4 list-disc space-y-6 pl-6 text-lg text-gray-600 dark:text-gray-400">
          <li>
            <strong class="text-gray-900 dark:text-gray-200">Gestión de usuarios y autenticación</strong>
            <ul class="mt-2 list-disc space-y-1 pl-6 text-base">
              <li>Registro, inicio de sesión y control de accesos.</li>
              <li>Autenticación basada en tokens JWT y OAuth2.</li>
              <li>Verificación de correo electrónico.</li>
            </ul>
          </li>

          <li>
            <strong class="text-gray-900 dark:text-gray-200">Registros energéticos</strong>
            <ul class="mt-2 list-disc space-y-1 pl-6 text-base">
              <li>Registro de producción por fuente y periodo.</li>
              <li>Cálculo automático por país en reducción de emisiones.</li>
              <li>Visualización de los tipos de energía más utilizados.</li>
            </ul>
          </li>

          <li>
            <strong class="text-gray-900 dark:text-gray-200">Microservicios</strong>
            <ul class="mt-2 list-disc space-y-1 pl-6 text-base">
              <li>Microservicio de usuarios.</li>
              <li>Microservicio de energía.</li>
              <li>Microservicio de análisis de datos.</li>
              <li>Microservicio de autenticación.</li>
            </ul>
          </li>

          <li>
            <strong class="text-gray-900 dark:text-gray-200">Dashboards y reportes</strong>
            <ul class="mt-2 list-disc space-y-1 pl-6 text-base">
              <li>Métricas de emisiones.</li>
              <li>Gráficos exportables.</li>
            </ul>
          </li>
        </ul>
      </section>
    </SectionContainer>

    <div class="space-y-24">
      <SectionContainer>
        <TitleSection>
          <Tools class="size-7" />
          Arquitectura y diseño
        </TitleSection>
        <figure class="mt-4 overflow-hidden rounded-xl border border-gray-200 shadow-lg dark:border-gray-700">
          <img
            src="/enerTrack-architecture.webp"
            alt="Diagrama de arquitectura de microservicios de EnerTrack"
            class="w-full object-cover"
            loading="lazy"
          />
        </figure>
      </SectionContainer>

      <SectionContainer>
        <TitleSection>
          <Tools class="size-7" />
          Tecnologías utilizadas
        </TitleSection>

        <div>
          <h3 class="mb-2 text-lg font-semibold text-gray-900 dark:text-white">Back-end</h3>
          <ul class="max-w-md list-inside list-disc space-y-1 text-gray-600 dark:text-gray-400">
            <li>Spring Boot</li>
            <li>Spring Security</li>
            <li>Spring Cloud</li>
            <li>PostgreSQL</li>
            <li>MySQL</li>
            <li>Docker</li>
            <li>Kubernetes</li>
            <li>Angular</li>
          </ul>
        </div>

        <div class="mt-6">
          <h3 class="mb-2 text-lg font-semibold text-gray-900 dark:text-white">Front-end</h3>
          <ul class="max-w-md list-inside list-disc space-y-1 text-gray-600 dark:text-gray-400">
            <li>Angular</li>
            <li>Tailwind CSS</li>
          </ul>
        </div>
      </SectionContainer>
    </div>
  </main>
</Layout>
